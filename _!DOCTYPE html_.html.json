<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>Apex Crown High School - Admin Dashboard</title>

        <style>
            *{
                      margin:0;
                            padding:0;
                                  box-sizing:border-box;
                                        font-family:Arial, sans-serif;
            }

                body{
                          background:#f3f4f6;
                                color:#222;
                }

                    :root{
                              --purple:#4b0082;
                                    --silver:#c0c0c0;
                                          --white:#fff;
                                                --dark:#1f1f1f;
                    }

                        .container{
                                  display:flex;
                                        min-height:100vh;
                        }

                            /* Sidebar */
                                .sidebar{
                                          width:260px;
                                                background:var(--purple);
                                                      color:white;
                                                            padding:20px;
                                                                  position:fixed;
                                                                        top:0;
                                                                              left:0;
                                                                                    height:100%;
                                                                                          overflow:auto;
                                }

                                    .sidebar h2{
                                              font-size:22px;
                                                    margin-bottom:5px;
                                    }

                                        .sidebar p{
                                                  color:var(--silver);
                                                        margin-bottom:30px;
                                                              font-size:14px;
                                        }

                                            .sidebar ul{
                                                      list-style:none;
                                            }

                                                .sidebar ul li{
                                                          padding:15px;
                                                                margin-bottom:10px;
                                                                      background:rgba(255,255,255,0.1);
                                                                            border-radius:8px;
                                                                                  cursor:pointer;
                                                                                        transition:0.3s;
                                                }

                                                    .sidebar ul li:hover{
                                                              background:var(--silver);
                                                                    color:var(--purple);
                                                    }

                                                        /* Main */
                                                            .main{
                                                                      margin-left:260px;
                                                                            padding:20px;
                                                                                  width:100%;
                                                            }

                                                                .topbar{
                                                                          display:flex;
                                                                                justify-content:space-between;
                                                                                      align-items:center;
                                                                                            margin-bottom:20px;
                                                                }

                                                                    .topbar button{
                                                                              padding:10px 15px;
                                                                                    border:none;
                                                                                          background:var(--purple);
                                                                                                color:white;
                                                                                                      border-radius:6px;
                                                                                                            cursor:pointer;
                                                                    }

                                                                        /* Cards */
                                                                            .cards{
                                                                                      display:grid;
                                                                                            grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
                                                                                                  gap:20px;
                                                                                                        margin-bottom:30px;
                                                                            }

                                                                                .card{
                                                                                          background:white;
                                                                                                padding:20px;
                                                                                                      border-radius:10px;
                                                                                                            box-shadow:0 2px 8px rgba(0,0,0,0.1);
                                                                                                                  border-left:5px solid var(--purple);
                                                                                }

                                                                                    .card h3{
                                                                                              margin-bottom:10px;
                                                                                                    color:var(--purple);
                                                                                    }

                                                                                        .card p{
                                                                                                  font-size:28px;
                                                                                                        font-weight:bold;
                                                                                        }

                                                                                            /* Sections */
                                                                                                .section{
                                                                                                          background:white;
                                                                                                                padding:20px;
                                                                                                                      border-radius:10px;
                                                                                                                            margin-bottom:20px;
                                                                                                                                  box-shadow:0 2px 8px rgba(0,0,0,0.1);
                                                                                                }

                                                                                                    .section h2{
                                                                                                              margin-bottom:20px;
                                                                                                                    color:var(--purple);
                                                                                                    }

                                                                                                        table{
                                                                                                                  width:100%;
                                                                                                                        border-collapse:collapse;
                                                                                                        }

                                                                                                            table th, table td{
                                                                                                                      padding:12px;
                                                                                                                            border-bottom:1px solid #ddd;
                                                                                                                                  text-align:left;
                                                                                                            }

                                                                                                                table th{
                                                                                                                          background:var(--purple);
                                                                                                                                color:white;
                                                                                                                }

                                                                                                                    .btn{
                                                                                                                              padding:8px 12px;
                                                                                                                                    border:none;
                                                                                                                                          border-radius:5px;
                                                                                                                                                cursor:pointer;
                                                                                                                                                      color:white;
                                                                                                                    }

                                                                                                                        .approve{
                                                                                                                                  background:green;
                                                                                                                        }

                                                                                                                            .reject{
                                                                                                                                      background:red;
                                                                                                                            }

                                                                                                                                .publish{
                                                                                                                                          background:var(--purple);
                                                                                                                                }

                                                                                                                                    /* Login */
                                                                                                                                        .login-screen{
                                                                                                                                                  height:100vh;
                                                                                                                                                        display:flex;
                                                                                                                                                              justify-content:center;
                                                                                                                                                                    align-items:center;
                                                                                                                                                                          background:linear-gradient(135deg,var(--purple),#2d003f);
                                                                                                                                        }

                                                                                                                                            .login-box{
                                                                                                                                                      background:white;
                                                                                                                                                            padding:40px;
                                                                                                                                                                  border-radius:12px;
                                                                                                                                                                        width:350px;
                                                                                                                                                                              text-align:center;
                                                                                                                                            }

                                                                                                                                                .login-box h1{
                                                                                                                                                          color:var(--purple);
                                                                                                                                                                margin-bottom:10px;
                                                                                                                                                }

                                                                                                                                                    .login-box p{
                                                                                                                                                              margin-bottom:20px;
                                                                                                                                                                    color:#666;
                                                                                                                                                    }

                                                                                                                                                        .login-box input{
                                                                                                                                                                  width:100%;
                                                                                                                                                                        padding:12px;
                                                                                                                                                                              margin-bottom:15px;
                                                                                                                                                                                    border:1px solid #ccc;
                                                                                                                                                                                          border-radius:6px;
                                                                                                                                                        }

                                                                                                                                                            .login-box button{
                                                                                                                                                                      width:100%;
                                                                                                                                                                            padding:12px;
                                                                                                                                                                                  border:none;
                                                                                                                                                                                        background:var(--purple);
                                                                                                                                                                                              color:white;
                                                                                                                                                                                                    border-radius:6px;
                                                                                                                                                                                                          cursor:pointer;
                                                                                                                                                                                                                font-size:16px;
                                                                                                                                                            }

                                                                                                                                                                .hidden{
                                                                                                                                                                          display:none;
                                                                                                                                                                }

                                                                                                                                                                    @media(max-width:768px){

                                                                                                                                                                              .sidebar{
                                                                                                                                                                                        width:100%;
                                                                                                                                                                                                height:auto;
                                                                                                                                                                                                        position:relative;
                                                                                                                                                                              }

                                                                                                                                                                                    .main{
                                                                                                                                                                                                margin-left:0;
                                                                                                                                                                                    }

                                                                                                                                                                                          .container{
                                                                                                                                                                                                    flex-direction:column;
                                                                                                                                                                                          }
                                                                                                                                                                    }
                                                                                                                                                                      </style>
                                                                                                                                                                      </head>

                                                                                                                                                                      <body>

                                                                                                                                                                        <!-- LOGIN SCREEN -->
                                                                                                                                                                          <div id="loginScreen" class="login-screen">
                                                                                                                                                                              <div class="login-box">
                                                                                                                                                                                    <h1>Apex Crown High School</h1>
                                                                                                                                                                                          <p>Raising Leaders, Shaping Futures</p>

                                                                                                                                                                                                <input type="email" id="email" placeholder="Admin Email">
                                                                                                                                                                                                      <input type="password" id="password" placeholder="Password">

                                                                                                                                                                                                            <button onclick="login()">Admin Login</button>

                                                                                                                                                                                                                  <br><br>
                                                                                                                                                                                                                        <small id="loginMessage"></small>
                                                                                                                                                                                                                            </div>
                                                                                                                                                                                                                              </div>

                                                                                                                                                                                                                                <!-- DASHBOARD -->
                                                                                                                                                                                                                                  <div id="dashboard" class="container hidden">

                                                                                                                                                                                                                                      <!-- SIDEBAR -->
                                                                                                                                                                                                                                          <div class="sidebar">
                                                                                                                                                                                                                                                <h2>Apex Crown HS</h2>
                                                                                                                                                                                                                                                      <p>Raising Leaders, Shaping Futures</p>

                                                                                                                                                                                                                                                            <ul>
                                                                                                                                                                                                                                                                    <li onclick="showSection('overview')">Dashboard</li>
                                                                                                                                                                                                                                                                            <li onclick="showSection('admissions')">Admissions</li>
                                                                                                                                                                                                                                                                                    <li onclick="showSection('results')">Results</li>
                                                                                                                                                                                                                                                                                            <li onclick="showSection('fees')">Fee Payments</li>
                                                                                                                                                                                                                                                                                                    <li onclick="showSection('students')">Students</li>
                                                                                                                                                                                                                                                                                                            <li onclick="showSection('staff')">Staff</li>
                                                                                                                                                                                                                                                                                                                  </ul>
                                                                                                                                                                                                                                                                                                                      </div>

                                                                                                                                                                                                                                                                                                                          <!-- MAIN CONTENT -->
                                                                                                                                                                                                                                                                                                                              <div class="main">

                                                                                                                                                                                                                                                                                                                                    <div class="topbar">
                                                                                                                                                                                                                                                                                                                                            <h1>Admin Dashboard</h1>
                                                                                                                                                                                                                                                                                                                                                    <button onclick="logout()">Logout</button>
                                                                                                                                                                                                                                                                                                                                                          </div>

                                                                                                                                                                                                                                                                                                                                                                <!-- OVERVIEW -->
                                                                                                                                                                                                                                                                                                                                                                      <div id="overview" class="content-section">

                                                                                                                                                                                                                                                                                                                                                                              <div class="cards">
                                                                                                                                                                                                                                                                                                                                                                                        <div class="card">
                                                                                                                                                                                                                                                                                                                                                                                                    <h3>Total Students</h3>
                                                                                                                                                                                                                                                                                                                                                                                                                <p id="studentCount">0</p>
                                                                                                                                                                                                                                                                                                                                                                                                                          </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                    <div class="card">
                                                                                                                                                                                                                                                                                                                                                                                                                                                <h3>Total Staff</h3>
                                                                                                                                                                                                                                                                                                                                                                                                                                                            <p id="staffCount">0</p>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <div class="card">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <h3>Admissions</h3>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <p id="admissionCount">0</p>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <div class="card">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <h3>Payments</h3>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <p id="paymentCount">0</p>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <!-- ADMISSIONS -->
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <div id="admissions" class="content-section hidden">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <div class="section">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          <h2>Admissions Management</h2>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <table>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <thead>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <th>Name</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <th>Class</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <th>Status</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <th>Action</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        </thead>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <tbody id="admissionTable"></tbody>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              </table>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <!-- RESULTS -->
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <div id="results" class="content-section hidden">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <div class="section">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          <h2>Results Management</h2>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <input type="text" id="resultStudent" placeholder="Student Name">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <input type="text" id="resultScore" placeholder="Score">

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <button class="btn publish" onclick="uploadResult()">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    Upload Result
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              </button>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <br><br>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <table>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <thead>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <th>Student</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <th>Score</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <th>Status</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </thead>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <tbody id="resultsTable"></tbody>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </table>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <!-- FEES -->
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <div id="fees" class="content-section hidden">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <div class="section">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <h2>Fee Payment Tracking</h2>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <table>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <thead>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <th>Student</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <th>Amount</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <th>Status</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </thead>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <tbody id="feesTable"></tbody>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </table>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <!-- STUDENTS -->
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <div id="students" class="content-section hidden">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <div class="section">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <h2>Student Management</h2>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <table>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <thead>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <th>Name</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <th>Class</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <th>Gender</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </thead>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <tbody id="studentsTable"></tbody>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </table>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </div>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <!-- STAFF -->
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <div id="staff" class="content-section hidden">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <div class="section">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <h2>Staff Management</h2>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <table>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <thead>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <th>Name</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <th>Department</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <th>Position</th>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </thead>

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <tbody id="staffTable"></tbody>
